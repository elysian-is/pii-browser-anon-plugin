{
  "version": "1.0.0",

  "regexPatterns": [
    {
      "id": "ssn",
      "label": "SSN / Tax ID",
      "category": "ssn",
      "pattern": "\\b\\d{3}-\\d{2}-\\d{4}\\b",
      "flags": "g"
    },
    {
      "id": "fein",
      "label": "FEIN / Tax ID (XX-XXXXXXX)",
      "category": "ssn",
      "pattern": "\\b\\d{2}-\\d{7}\\b",
      "flags": "g"
    },
    {
      "id": "phone_us",
      "label": "Phone Number (US)",
      "category": "phone",
      "pattern": "\\b\\(?\\d{3}\\)?[-.\\ ]?\\d{3}[-.\\ ]?\\d{4}\\b",
      "flags": "g"
    },
    {
      "id": "email",
      "label": "Email Address",
      "category": "email",
      "pattern": "\\b[A-Za-z0-9._%+\\-]+@[A-Za-z0-9.\\-]+\\.[A-Za-z]{2,}\\b",
      "flags": "gi"
    },
    {
      "id": "currency",
      "label": "Dollar Amount",
      "category": "currency",
      "pattern": "\\$\\s?[\\d,]+\\.?\\d{0,2}\\b",
      "flags": "g"
    },
    {
      "id": "date_us",
      "label": "Date (US format)",
      "category": "dates",
      "pattern": "\\b\\d{1,2}\\/\\d{1,2}\\/\\d{2,4}\\b",
      "flags": "g"
    },
    {
      "id": "date_iso",
      "label": "Date (ISO format)",
      "category": "dates",
      "pattern": "\\b\\d{4}-\\d{2}-\\d{2}\\b",
      "flags": "g"
    },
    {
      "id": "claim_number",
      "label": "Claim Number",
      "category": "claimNumbers",
      "pattern": "\\b[A-Z]{2,4}-?\\d{6,12}\\b",
      "flags": "g"
    },
    {
      "id": "policy_number",
      "label": "Policy Number",
      "category": "claimNumbers",
      "pattern": "\\b[A-Z]{2,5}\\d{6,10}\\b",
      "flags": "g"
    },
    {
      "id": "zip_code",
      "label": "ZIP Code",
      "category": "addresses",
      "pattern": "\\b\\d{5}(-\\d{4})?\\b",
      "flags": "g"
    },
    {
      "id": "street_address",
      "label": "Street Address",
      "category": "addresses",
      "pattern": "\\b\\d{1,5}\\s[A-Z][a-z]+\\s(St|Ave|Blvd|Dr|Rd|Ln|Way|Ct|Pl|Ter|Circle|Cir)\\.?\\b",
      "flags": "gi"
    },
    {
      "id": "icd10",
      "label": "ICD-10 Medical Code",
      "category": "medicalCodes",
      "pattern": "\\b[A-Z]\\d{2,3}\\.?\\d{0,4}\\b",
      "flags": "g"
    }
  ],

  "selectorRules": [
